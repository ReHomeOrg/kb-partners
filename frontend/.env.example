# Конфигурация фронтенда kb-partners (портал партнёра LIGHT, E10).
# Скопируйте в .env.local для локальной разработки. Секреты в репозиторий НЕ коммитим.

# Секрет шифрования сессионного JWT (Auth.js). Сгенерировать: `openssl rand -base64 32`.
AUTH_SECRET=

# Keycloak client фронта (confidential), зарегистрированный в kb-auth.
AUTH_KEYCLOAK_ID=kb-partners-frontend
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=https://keycloak.rehome.local/realms/rehome

# Базовый URL API kb-partners, к которому фронт ходит с Bearer (корень хоста).
KB_PARTNERS_API_BASE_URL=http://localhost:8000

# --- ВАЖНО (kb-auth / ops) -------------------------------------------------
# Access token client'а ДОЛЖЕН содержать `aud: kb-partners` (verify_aud бэкенда),
# и роль/скоуп партнёра (partner) — иначе бэкенд отклонит/не покажет заявки.
# ---------------------------------------------------------------------------
