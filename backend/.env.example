# Конфигурация kb-partners backend (local dev). Скопируйте в `.env`.
# Секреты в репозиторий НЕ коммитим. Префикс всех переменных — KBP_.

# --- База данных (порт 5434 из docker-compose) ---
KBP_DATABASE_URL=postgresql+asyncpg://kbpartners:devpass@localhost:5434/kbpartners

# --- Логирование ---
KBP_LOG_LEVEL=INFO

# --- Keycloak Bearer JWT. Пусто → auth fail-closed (401 на всё).
# aud токена фронта/агента ДОЛЖЕН содержать `kb-partners` (verify_aud). ---
KBP_AUTH_JWKS_URL=
KBP_AUTH_ISSUER=
KBP_AUTH_AUDIENCE=kb-partners

# --- Redis (кеш HTTP-клиентов + брокер Dramatiq) ---
KBP_REDIS_URL=redis://localhost:6379/0

# --- Соседи (m2m). Пустой токен → интеграция инертна (заглушка). ---
KBP_PLATFORM_API_BASE_URL=http://localhost:8081
KBP_PLATFORM_API_TOKEN=
KBP_REHOME_ONE_API_BASE_URL=http://localhost:8080
KBP_REHOME_ONE_API_TOKEN=
KBP_KB_FILES_API_BASE_URL=http://localhost:8084
KBP_KB_FILES_API_TOKEN=
KBP_KB_SEARCH_API_BASE_URL=http://localhost:8082
KBP_KB_SEARCH_API_TOKEN=
KBP_KB_SUPPORT_API_BASE_URL=http://localhost:8000
KBP_KB_SUPPORT_API_TOKEN=

# --- Dramatiq-воркер. Пусто → StubBroker (акторы инертны). ---
KBP_WORKER_BROKER_URL=
